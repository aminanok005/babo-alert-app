{
  "name": "1 Script → 7 Clips Generator",
  "nodes": [
    {
      "parameters": {},
      "id": "manual-trigger",
      "name": "Manual Trigger",
      "type": "n8n-nodes-base.manualTrigger",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer {{$env.GROQ_API_KEY}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
              "value": "llama-3.1-70b-versatile"
            },
            {
              "name": "messages",
              "value": [
                {
                  "role": "system",
                  "content": "คุณคือผู้เชี่ยวชาญการเขียนสคริปต์วิดีโอสั้น สร้างสคริปต์ภาษาไทยที่แบ่งเป็น 7 ส่วนชัดเจน: 1)Hook 2)Problem 3-7)Solution/Tips 8)CTA แต่ละส่วนไม่เกิน 100 คำ"
                },
                {
                  "role": "user",
                  "content": "สร้างสคริปต์วิดีโอเกี่ยวกับ: {{$json.topic}}"
                }
              ]
            },
            {
              "name": "temperature",
              "value": 0.7
            },
            {
              "name": "max_tokens",
              "value": 2000
            }
          ]
        },
        "options": {}
      },
      "id": "groq-generate",
      "name": "Generate Script",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [450, 300]
    },
    {
      "parameters": {
        "functionCode": "// Split script into 7 parts\nconst fullScript = items[0].json.choices[0].message.content;\nconst topic = items[0].json.topic;\n\n// Split by numbered sections\nconst parts = fullScript.split(/\\d+\\)[\\s\\n]+/).filter(p => p.trim().length > 10);\n\n// Create array for loop\nreturn parts.slice(0, 7).map((text, idx) => ({\n  json: {\n    clip_number: idx + 1,\n    text: text.trim(),\n    tone: idx === 0 ? 'exciting' : idx === 6 ? 'persuasive' : 'informative',\n    is_hero: [1, 7].includes(idx + 1),\n    topic: topic\n  }\n}}));"
      },
      "id": "split-script",
      "name": "Split Script",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [650, 300]
    },
    {
      "parameters": {
        "batchSize": 1
      },
      "id": "loop-over-items",
      "name": "Loop Over Clips",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [850, 300]
    },
    {
      "parameters": {
        "command": "python3",
        "parametersToPass": [
          "{{ $json.clip_number }}",
          "{{ $json.text }}",
          "{{ $json.is_hero }}"
        ],
        "workingDirectory": "/home/nisreen/ai-lab/n8n/babo-alert-app"
      },
      "id": "tts-edge",
      "name": "Generate TTS",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [1050, 250],
      "continueOnFail": false
    },
    {
      "parameters": {
        "command": "bash",
        "parametersToPass": [
          "{{ $json.clip_number }}",
          "{{ $json.text }}",
          "output/clip_{{ $json.clip_number }}.mp4"
        ],
        "workingDirectory": "/home/nisreen/ai-lab/n8n/babo-alert-app"
      },
      "id": "render-video",
      "name": "Render Video",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [1050, 400],
      "continueOnFail": false
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.telegram.org/bot{{$env.TELEGRAM_BOT_TOKEN}}/sendMessage",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "chat_id",
              "value": "{{$env.TELEGRAM_CHAT_ID}}"
            },
            {
              "name": "text",
              "value": "✅ สร้างวิดีโอคลิปที่ {{$json.clip_number}} เสร็จแล้ว!\nหัวข้อ: {{$json.topic}}"
            }
          ]
        },
        "options": {}
      },
      "id": "telegram-notify",
      "name": "Notify Telegram",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1250, 300]
    }
  ],
  "connections": {
